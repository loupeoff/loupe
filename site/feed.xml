  <item>
    <title>VIDEO - 40 ans de Tchernobyl : que s’est-il passé dans le réacteur ?</title>
    <link>https://www.lemonde.fr/international/video/2026/04/25/tchernobyl-l-origine-d-une-catastrophe-atomique-plongee-en-3d-au-coeur-du-reacteur_6683273_3210.html</link>
    <guid isPermaLink="true">https://www.lemonde.fr/international/video/2026/04/25/tchernobyl-l-origine-d-une-catastrophe-atomique-plongee-en-3d-au-coeur-du-reacteur_6683273_3210.html</guid>
    <pubDate>Sat, 25 Apr 2026 19:54:53 +0000</pubDate>
    <category>Politique</category>
